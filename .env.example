# Base URL of the cguard backend API.
# In production the panel is served at app.cguardpro.com/superadmin and the
# backend is proxied at /api on the same origin, so the default "/api" works.
# Override only for split-origin setups.
VITE_API_URL=/api

# Dev-only: where `vite dev` proxies /api to (your local backend).
VITE_DEV_API_TARGET=http://localhost:8080
